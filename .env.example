# Optional local configuration for AVATRYX-SINJ.
#
# Copy this file to .env only if you need to override defaults.

# Express server port. Default: 5000
PORT=5000

# Optional: full path to the Python executable used for SINJ inference.
# Leave unset if you create the virtual environment at SINJ/sinj-env.
# Windows example:
# SINJ_PYTHON=C:\Users\you\path\to\AVATRYX-SINJ\SINJ\sinj-env\Scripts\python.exe
# macOS/Linux example:
# SINJ_PYTHON=/Users/you/path/to/AVATRYX-SINJ/SINJ/sinj-env/bin/python
